# Node modules
/node_modules/

# Build output
/dist/
/build/

# Logs
logs/
/*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS-specific files
.DS_Store

# Test files
/coverage/
/.nyc_output/

# IDEs and editors
/.idea/
/.project
.classpath
.c9/
/*.launch
.settings/
/*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# Temporary files
.temp/
/.tmp/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (Node.js)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Git files (Git internal files, usually not necessary to track)
FETCH_HEAD
HEAD
packed-refs

# Git hooks (You don't need to track sample hooks)
.git/hooks/*
!git/hooks/README.md  # Keep any necessary documentation if you want

# Git refs
.git/refs/
.git/objects/
.git/info/exclude
